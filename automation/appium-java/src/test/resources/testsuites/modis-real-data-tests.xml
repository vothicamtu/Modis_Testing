<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Modis Six Module Test Suite" verbose="1" parallel="false" thread-count="1">
    <parameter name="platform" value="android"/>
    <parameter name="deviceName" value="Android Emulator"/>
    <parameter name="platformVersion" value="11.0"/>

    <listeners>
        <listener class-name="com.modis.listeners.TestListener"/>
    </listeners>

    <test name="Authentication">
        <classes>
            <class name="com.modis.tests.AuthenticationTests"/>
        </classes>
    </test>

    <test name="Friend Management">
        <classes>
            <class name="com.modis.tests.FriendsTests"/>
        </classes>
    </test>

    <test name="Photo Sharing">
        <classes>
            <class name="com.modis.tests.PhotoSharingTests"/>
        </classes>
    </test>

    <test name="Feed">
        <classes>
            <class name="com.modis.tests.FeedTests"/>
        </classes>
    </test>

    <test name="Search">
        <classes>
            <class name="com.modis.tests.SearchTests"/>
        </classes>
    </test>

    <test name="Messaging">
        <classes>
            <class name="com.modis.tests.MessagingTests"/>
        </classes>
    </test>
</suite>
